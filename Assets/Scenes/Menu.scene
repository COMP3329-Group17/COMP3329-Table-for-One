      m_Calls: []
  m_text: "You play as a traveler who walks into a restaurant.\n\nBig mistake.\nThe
    door locks behind you. \nEmpty booths. Empty tables. Just you. Now you're trapped.\n\nThis
    restaurant was failing. Then it wasn't... \nCustomers keep coming back for the
    special. Every single night. \n\nSolve the puzzles. Unlock the cool room.\nDon't
    ask what the foul stench is. \nDon't ask what's in the special."
  m_enableAdvanceTextProcess: 0
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 48929287b33904d24af1eba705440c01, type: 2}
